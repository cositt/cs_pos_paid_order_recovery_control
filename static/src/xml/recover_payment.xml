<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="point_of_sale.TicketScreen" t-inherit-mode="extension">
        <xpath expr="//ActionpadWidget" position="before">
            <button
                t-if="isOrderSynced and canRecoverPayment"
                class="button btn btn-warning btn-lg py-3 w-100 mb-2"
                t-on-click="recoverPayment">
                🔙 Recuperar Pago
            </button>
        </xpath>
    </t>
</templates>
