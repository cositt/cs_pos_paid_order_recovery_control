<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Agregar botón "Editar Pago" en TicketScreen -->
    <t t-name="cs_pos_paid_order_recovery_control.TicketScreenEditPaymentButton"
       t-inherit="point_of_sale.TicketScreen"
       t-inherit-mode="extension">

        <!-- Agregar botón en la sección de acciones -->
        <xpath expr="//button" position="after">
            <button t-if="ticket?.finalized and ticket?.session_id?.id === pos?.session?.id"
                    class="btn btn-primary btn-lg edit-payment-btn"
                    t-on-click="() => this.editPayment(ticket)"
                    title="Editar pago: elimina los pagos actuales y permite configurar uno nuevo">
                <i class="fa fa-edit me-2" />
                Editar Pago
            </button>
        </xpath>

    </t>

</templates>
