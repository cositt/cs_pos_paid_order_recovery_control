<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Agregar botón "Recuperar Pedido" en TicketScreen -->
    <t t-name="cs_pos_paid_order_recovery_control.TicketScreenRecoveryButton"
       t-inherit="point_of_sale.TicketScreen"
       t-inherit-mode="extension">

        <!-- Agregar botón después de otros botones en la barra de acciones -->
        <xpath expr="//div[hasclass('button-section')]" position="inside">
            <button t-if="ticketScreen.currentOrder?.finalized and ticketScreen.currentOrder?.session_id?.id === pos.session?.id and !ticketScreen.currentOrder?.is_recovery"
                    class="btn btn-warning btn-lg recover-order-btn"
                    t-on-click="() => ticketScreen.recoverOrder(ticketScreen.currentOrder)"
                    title="Recuperar este pedido pagado: anular pago y crear nuevo editable">
                <i class="fa fa-undo me-2" />
                Recuperar Pedido
            </button>
        </xpath>

    </t>

</templates>
